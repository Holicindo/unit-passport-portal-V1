{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env TURBOPACK=0 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:run": "jest --runInBand"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.14.0",
    "next": "^16.2.7",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^.+\\.module\\.(css|sass|scss)$": "<rootDir>/__mocks__/styleMock.js",
      "^.+\\.(css|sass|scss)$": "<rootDir>/__mocks__/styleMock.js"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx",
            "esModuleInterop": true,
            "moduleResolution": "node"
          }
        }
      ]
    }
  }
}
